# Copy to .env for local development
# Never commit .env to git

ANTHROPIC_KEY=sk-ant-...

# Local dev
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
ALLOWED_HOSTS=localhost,127.0.0.1

# Production (set these as Railway env variables, not in .env)
# ALLOWED_ORIGINS=https://your-app.pages.dev,https://your-custom-domain.com
# ALLOWED_HOSTS=your-railway-app.railway.app

DEBUG=false

# FLUX API (Black Forest Labs) — for generating card images
# Get your key at https://dashboard.bfl.ai/
BFL_API_KEY=bfl_...
